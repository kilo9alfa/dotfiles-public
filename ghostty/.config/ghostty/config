# Ghostty configuration — mirrors David's VS Code look & feel.
# Picked up by Ghostty and by Supacode (built on libghostty).
# Apply: stowed from ~/code/dotfiles/ghostty/.config/ghostty/config

# ── Font (matches VS Code terminal.integrated.fontFamily) ──────────────────
font-family       = IoskeleyMono Nerd Font
font-size         = 14
# Disable ligatures to match editor.fontLigatures = false
font-feature      = -liga
font-feature      = -calt
font-feature      = -dlig
# Heavier glyph rendering (macOS) — keeps text crisp on the light theme
font-thicken      = true
# Extra line spacing for easier scanning of dense output
adjust-cell-height = 15%

# ── Cursor (matches editor.cursorBlinking = smooth) ────────────────────────
cursor-style          = block
cursor-style-blink    = true
shell-integration-features = cursor

# ── Colors — switch with system/cmux appearance ────────────────────────────
# Theme files live in themes/ next to this config.
# dpx-dark mirrors the VS Code Dark Modern overrides (previous hardcoded
# colors); dpx-light is a white terminal matching VS Code Light Modern.
theme = light:dpx-light,dark:dpx-dark
# Auto-fix ANSI colors too close to the background (bright yellow/green on white)
minimum-contrast = 1.3

# ── Window chrome ──────────────────────────────────────────────────────────
window-padding-x       = 8
window-padding-y       = 6
window-padding-balance = true
macos-titlebar-style   = transparent
background-opacity     = 1.0

# ── Misc ───────────────────────────────────────────────────────────────────
copy-on-select        = clipboard
mouse-hide-while-typing = true
confirm-close-surface = false
