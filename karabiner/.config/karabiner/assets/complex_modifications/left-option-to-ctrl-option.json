{
  "title": "Left Option → Ctrl+Option (for AeroSpace)",
  "rules": [
    {
      "description": "Map left_option to left_control + left_option so AeroSpace uses ctrl-alt, freeing right_option for symbols",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_option",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_option",
              "modifiers": ["left_control"]
            }
          ]
        }
      ]
    }
  ]
}
