{
    "zenMode.centerLayout": false,
    "breadcrumbs.enabled": false,
    "terminal.integrated.fontFamily": "IoskeleyMono Nerd Font",
    "terminal.integrated.tabs.title": "${process} — ${cwdFolder}",
    "terminal.integrated.tabs.description": "${cwd}",
    "claudeCode.preferredLocation": "panel",
    "claudeCode.autoOpenFiles": false,
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "tabstronaut.newTabGroupPosition": "top",
    "workbench.statusBar.visible": false,
    "editor.minimap.enabled": false,
    "tabstronaut.confirmRemoveAndClose": false,
    "tabstronaut.keybindingOrder": false,
    "tabstronaut.moveTabGroupOnTabChange": false,
    "tabstronaut.addPaths": false,
    "editor.bracketPairColorization.enabled": true,
    "editor.accessibilitySupport": "off",
    "workbench.experimental.share.enabled": true,
    "workbench.hover.delay": 100,
    "terminal.integrated.fontSize": 14,
    "editor.cursorBlinking": "smooth",
    "editor.find.addExtraSpaceOnTop": false,
    "notebook.output.wordWrap": true,
    "editor.defaultFormatter": "ms-python.vscode-python-envs",
    "editor.fontFamily": "IoskeleyMono, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontWeight": "normal",
    "editor.fontLigatures": false,
    "telemetry.editStats.enabled": false,
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off"
}